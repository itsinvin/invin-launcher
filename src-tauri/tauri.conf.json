{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "invin launcher",
  "version": "0.1.0",
  "identifier": "app.invin.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "invin launcher",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Game",
    "shortDescription": "Hardware-aware Minecraft launcher",
    "longDescription": "invin launcher predicts how modpacks will run on your hardware and manages instances, mods and accounts."
  },
  "plugins": {}
}
